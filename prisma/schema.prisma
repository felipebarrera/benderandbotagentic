datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Tenant {
  id                   String         @id @default(uuid()) @db.Uuid
  nombre               String
  whatsapp_number      String         @unique
  whatsapp_phone_id    String
  modo_bot             Boolean        @default(true)
  prompt_personalizado String?
  horario_inicio       String         @default("00:00")
  horario_fin          String         @default("23:59")
  activo               Boolean        @default(true)
  domain               String?
  telegram_chat_id     String?

  telegram_bot_token   String?
  created_at           DateTime       @default(now())
  updated_at           DateTime       @updatedAt
  agentes              Agente[]
  conversaciones       Conversacion[]

  @@map("tenants")
}

model Agente {
  id             String         @id @default(uuid()) @db.Uuid
  tenant_id      String         @db.Uuid
  tenant         Tenant         @relation(fields: [tenant_id], references: [id])
  email          String         @unique
  password_hash  String
  nombre         String
  rol            RolAgente
  online         Boolean        @default(false)
  ultimo_ping    DateTime?
  created_at     DateTime       @default(now())
  updated_at     DateTime       @updatedAt
  conversaciones Conversacion[]

  @@map("agentes")
}

enum RolAgente {
  SUPERADMIN
  ADMIN
  AGENTE
}

model Conversacion {
  id                    String       @id @default(uuid()) @db.Uuid
  tenant_id             String       @db.Uuid
  tenant                Tenant       @relation(fields: [tenant_id], references: [id])
  whatsapp_contact      String
  contact_name          String?
  estado                EstadoConv
  agente_id             String?      @db.Uuid
  agente                Agente?      @relation(fields: [agente_id], references: [id])
  ultimo_mensaje_at     DateTime
  handover_at           DateTime?
  handover_resolved_at  DateTime?
  handover_resolution   String?
  created_at            DateTime     @default(now())
  updated_at            DateTime     @updatedAt
  mensajes              Mensaje[]
  cola_espera           ColaEspera[]

  @@index([tenant_id, estado])
  @@map("conversaciones")
}

enum EstadoConv {
  BOT
  HUMANO
  CERRADA
}

model Mensaje {
  id                  String       @id @default(uuid()) @db.Uuid
  conversacion_id     String       @db.Uuid
  conversacion        Conversacion @relation(fields: [conversacion_id], references: [id])
  tenant_id           String       @db.Uuid
  whatsapp_message_id String       @unique
  direccion           DireccionMsg
  tipo                TipoMsg
  contenido           String
  intent_detected     String?
  procesado           Boolean      @default(false)
  created_at          DateTime     @default(now())

  @@index([conversacion_id, created_at])
  @@index([tenant_id, created_at])
  @@map("mensajes")
}

enum DireccionMsg {
  ENTRANTE
  SALIENTE
}

enum TipoMsg {
  TEXTO
  AUDIO
  IMAGEN
  SISTEMA
}

model ColaEspera {
  id              String       @id @default(uuid()) @db.Uuid
  tenant_id       String       @db.Uuid
  conversacion_id String       @db.Uuid
  conversacion    Conversacion @relation(fields: [conversacion_id], references: [id])
  prioridad       Int          @default(0)
  created_at      DateTime     @default(now())

  @@map("cola_espera")
}

model Prospecto {
  id              Int       @id @default(autoincrement())
  canal           String    // 'whatsapp' | 'telegram'
  canalId         String    // phone o telegram_id
  nombre          String?
  perfil          String?   // 'profesional' | 'negocio' | 'emprendedor' | 'referido'
  rubroDetectado  String?
  estado          String    @default("nuevo")
  // nuevo | calculadora | demo | conversion | convertido | perdido
  refTenantSlug   String?   // slug del tenant que lo refirió
  datosJson       Json?     // respuestas del flujo
  mrrCalculado    Int?      // ingreso estimado en CLP
  createdAt       DateTime  @default(now())
  ultimoMensaje   DateTime?
  convertidoAt    DateTime?
  tenantSlug      String?   // si ya convirtió
  conversaciones  ConversacionCaptacion[]

  @@map("prospectos")
}

model ConversacionCaptacion {
  id           Int       @id @default(autoincrement())
  prospectoId  Int
  prospecto    Prospecto @relation(fields: [prospectoId], references: [id])
  canal        String
  rol          String    // 'bot' | 'user'
  contenido    String
  intencion    String?
  timestamp    DateTime  @default(now())

  @@map("conversaciones_captacion")
}

model Referido {
  id             Int       @id @default(autoincrement())
  referidorSlug  String    // tenant que refirió
  prospectoId    Int
  estado         String    @default("pendiente")
  // pendiente | convertido | expirado
  mesesGanados   Int       @default(0)
  createdAt      DateTime  @default(now())
  convertidoAt   DateTime?

  @@map("referidos")
}

model TenantNivel {
  id              Int       @id @default(autoincrement())
  tenantSlug      String    @unique
  nivelActual     Int       @default(1)
  metaVentasMes   Int       // CLP, calculado por rubro al onboardear
  ventasMes1      Int       @default(0)
  ventasMes2      Int       @default(0)
  ventasMes3      Int       @default(0)
  mesesEnMeta     Int       @default(0)
  logrosJson      Json      @default("[]")
  updatedAt       DateTime  @updatedAt

  @@map("tenants_nivel")
}

